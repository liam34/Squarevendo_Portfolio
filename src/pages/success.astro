---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Message Sent | Squarevendo">
	<Navigation />
	
	<main style="margin-top: 100px; padding: 2rem;">
		<div class="success-card">
			<i class="ri-checkbox-circle-fill"></i>
			<h1>Thank You!</h1>
			<p>Your message has been sent successfully. 
				<br>I will get back to you as soon as possible.</p>
			<a href="/">
				<i class="ri-arrow-left-line" style="margin-right: 0.5rem; vertical-align: middle;"></i>
				Back to Home
			</a>
		</div>
	</main>

	<Footer />
</Layout>

<style>
	.success-card {
		max-width: 600px;
		margin: 3rem auto;
		padding: 3rem;
		background-color: #f5f5f1;
		border-radius: 12px;
		text-align: center;
		box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
	}

	.success-card i {
		font-size: 4rem;
		color: #10b981;
		margin-bottom: 1rem;
		display: block;
	}

	.success-card h1 {
		font-size: 2.5rem;
		color: #2d2d2d;
		margin-bottom: 1rem;
		font-weight: 700;
	}

	.success-card p {
		font-size: 1rem;
		color: #4a4a4a;
		margin-bottom: 2rem;
		line-height: 1.6;
	}

	.success-card a {
		display: inline-block;
		padding: 0.75rem 1.5rem;
		background-color: #3b82f6;
		color: white;
		border-radius: 8px;
		text-decoration: none;
		font-weight: 600;
		transition: all 0.3s ease;
	}

	.success-card a:hover {
		background-color: #2563eb;
		transform: translateY(-2px);
	}
</style>
